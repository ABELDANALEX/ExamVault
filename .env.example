# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (defaults to ./examvault.db if unset)
# DB_PATH=./examvault.db

# ── Admin account ─────────────────────────────────────────────────────────────
# Password set on the default admin account during first-run seeding.
DEFAULT_ADMIN_PASSWORD=changeme

# ── Session / security ────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string
HANDOVER_SECRET=replace-with-another-long-random-string

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Choose ONE of: SMTP_HOST (custom server) OR SMTP_SERVICE (nodemailer well-known).
# Leave both blank to disable email entirely.

# Custom SMTP server
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true = TLS on port 465
# SMTP_USER=user@yourdomain.com
# SMTP_PASS=yourpassword

# Well-known service shorthand (overrides SMTP_HOST when set)
# SMTP_SERVICE=Gmail

# The From address that appears on outgoing mail
# SMTP_FROM=no-reply@yourdomain.com

# Admin address that receives key-dispatch notification emails.
# Leave blank to disable the notification (email is still configured above).
# ADMIN_NOTIFY_EMAIL=admin@yourdomain.com

# Set to "true" to use nodemailer's JSON transport (logs mail to stdout).
# Useful for local development — never use in production.
# EMAIL_JSON_TRANSPORT=false

# ── SMS (Twilio) ───────────────────────────────────────────────────────────────
# Used to send the access key directly to the Exam Cell phone number.
# Run `npm install twilio` after filling these in.
# Leave blank to disable SMS dispatch.
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15550001234   # Your Twilio number in E.164 format
